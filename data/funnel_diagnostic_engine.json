{
  "name": "Funnel Diagnostic Engine",
  "description": "Maps business conditions to exact funnel architecture, page types, elements, copy formulas, and design patterns",
  "model": "EventMath chain + split/path decision tree",
  "condition_dimensions": {
    "industry": {
      "description": "What industry/business type",
      "values": [
        "healthcare",
        "ecommerce_physical",
        "ecommerce_digital",
        "saas",
        "service_local",
        "service_professional",
        "coaching",
        "education_course",
        "event_summit",
        "nonprofit",
        "publishing_media",
        "real_estate"
      ],
      "weight": 10
    },
    "price_tier": {
      "description": "Price point of primary offer",
      "values": [
        "free_zero",
        "low_1_50",
        "medium_50_200",
        "high_200_1000",
        "premium_1000_5000",
        "enterprise_5000plus"
      ],
      "weight": 9
    },
    "customer_awareness": {
      "description": "How aware is the customer of their problem/solution",
      "values": [
        "unaware",
        "problem_aware",
        "solution_aware",
        "product_aware",
        "most_aware"
      ],
      "weight": 8
    },
    "purchase_frequency": {
      "description": "How often does the customer buy",
      "values": [
        "one_time",
        "recurring_monthly",
        "recurring_yearly",
        "infrequent",
        "lifetime"
      ],
      "weight": 7
    },
    "customer_relationship": {
      "description": "Relationship with customer",
      "values": [
        "cold_new",
        "warm_referral",
        "returning",
        "partner_affiliate",
        "enterprise_account"
      ],
      "weight": 6
    },
    "urgency": {
      "description": "How urgently does the customer need a solution",
      "values": [
        "immediate_hours",
        "same_week",
        "this_month",
        "no_rush",
        "future_planning"
      ],
      "weight": 5
    },
    "commitment_level": {
      "description": "How much commitment is required",
      "values": [
        "low_email",
        "medium_form",
        "high_payment",
        "very_high_application_callback"
      ],
      "weight": 4
    },
    "distribution_channel": {
      "description": "Primary channel for traffic",
      "values": [
        "organic_search",
        "paid_ads",
        "email_list",
        "social_organic",
        "social_paid",
        "referral",
        "in_person",
        "partner"
      ],
      "weight": 3
    },
    "buyer_type": {
      "description": "Who is buying",
      "values": [
        "b2c_individual",
        "b2b_small_business",
        "b2b_enterprise",
        "b2b_agency",
        "nonprofit_org"
      ],
      "weight": 2
    }
  },
  "decision_rules": [
    {
      "name": "tripwire_funnel",
      "when": {
        "industry_contains": [
          "ecommerce_physical",
          "ecommerce_digital"
        ],
        "price_tier": [
          "low_1_50",
          "medium_50_200"
        ],
        "customer_awareness": [
          "problem_aware",
          "solution_aware"
        ],
        "purchase_frequency": [
          "one_time"
        ],
        "commitment_level": [
          "low_email",
          "medium_form"
        ]
      },
      "then": {
        "funnel": "tripwire",
        "pages": [
          "optin",
          "upsell",
          "order",
          "thank_you"
        ],
        "elements": {
          "optin": [
            "hero_headline",
            "subheadline",
            "product_image",
            "benefit_bullets",
            "testimonials",
            "countdown_timer",
            "cta_button"
          ],
          "upsell": [
            "wait_headline",
            "value_stack",
            "strikethrough_pricing",
            "discount_price",
            "guarantee"
          ],
          "order": [
            "contact_form",
            "shipping_form",
            "payment_selection",
            "product_table",
            "submit_button"
          ],
          "thank_you": [
            "congrats_headline",
            "product_receipt",
            "facebook_group",
            "community_cta"
          ]
        },
        "copy_formula": "pain_agitation_solution",
        "design_palette": "blue_orange",
        "urgency_pattern": "countdown_timer"
      }
    },
    {
