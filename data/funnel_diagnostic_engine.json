  "element_usage_map": {
    "navbar": {
      "when": "More than 1 page in funnel, or brand recognition needed",
      "alternatives": [
        {
          "option": "transparent_over_hero",
          "when": "Hero has dark background image, nav needs to float"
        },
        {
          "option": "solid_white_bar",
          "when": "Light hero or content-heavy page, needs separation"
        },
        {
          "option": "glassmorphism",
          "when": "Modern design, video background, premium feel"
        },
        {
          "option": "minimal_logo_only",
          "when": "Single-purpose landing page, maximum focus on CTA"
        },
        {
          "option": "logo_phone_cta",
          "when": "Service business where phone call is a primary conversion"
        }
      ]
    },
    "hero_background": {
      "when": "First page of funnel, need to establish context fast",
      "alternatives": [
        {
          "option": "image_with_dark_overlay",
          "when": "Service/healthcare \u2014 show the service in action"
        },
        {
          "option": "video_background",
          "when": "Premium product, entertainment, high engagement"
        },
        {
          "option": "gradient_only",
          "when": "B2B SaaS, clean modern, fast load needed"
        },
        {
          "option": "solid_color",
          "when": "Lead magnet, minimal distraction, maximum text focus"
        },
        {
          "option": "pattern_texture",
          "when": "Creative/design brands, artistic feel"
        }
      ]
    },
    "headline_type": {
      "when": "Every page needs a headline \u2014 type depends on page goal",
      "alternatives": [
        {
          "option": "category_first",
          "when": "SEO-critical page, user searching for service type"
        },
        {
          "option": "pain_first",
          "when": "User is actively suffering, problem-aware visitor"
        },
        {
          "option": "benefit_first",
          "when": "User knows solution exists, needs best option"
        },
        {
          "option": "curiosity_gap",
          "when": "Cold traffic, needs intrigue to continue reading"
        },
        {
          "option": "social_proof_first",
          "when": "High skepticism industry, trust is primary barrier"
        },
        {
          "option": "question_headline",
          "when": "Engagement-focused, quiz/survey, self-identification"
        }
      ]
    },
    "cta_button": {
      "when": "Every page needs exactly ONE primary CTA",
      "alternatives": [
        {
          "option": "free_trial",
          "when": "SaaS, subscription, low commitment barrier"
        },
        {
          "option": "free_consultation",
          "when": "Service business, high ticket, requires callback"
        },
        {
          "option": "buy_now",
          "when": "E-commerce, known product, purchase-ready visitor"
        },
        {
          "option": "get_access",
          "when": "Digital product, course, membership"
        },
        {
          "option": "learn_more",
          "when": "Top of funnel, cold traffic, education needed"
        },
        {
          "option": "book_appointment",
          "when": "Healthcare, professional services, scheduling needed"
        },
        {
          "option": "download_free",
          "when": "Lead magnet, content offer, email capture"
        },
        {
          "option": "claim_offer",
          "when": "One-time offer, scarcity-driven, urgency required"
        }
      ]
    },
    "testimonials": {
      "when": "Trust is a conversion barrier \u2014 use on high-commitment pages",
      "alternatives": [
        {
          "option": "photo_name_stars",
          "when": "Standard social proof, works for most industries"
        },
        {
          "option": "video_testimonial",
          "when": "High ticket, healthcare, coaching \u2014 faces build trust"
        },
        {
          "option": "case_study_grid",
          "when": "B2B, SaaS, enterprise \u2014 needs results not quotes"
        },
        {
          "option": "logo_wall",
          "when": "B2B, established brands as clients"
        },
        {
          "option": "before_after",
          "when": "Physical transformation, weight loss, fitness, beauty"
        },
        {
          "option": "stat_counter",
          "when": "Volume-based trust \u2014 '10,000+ customers served'"
        }
      ]
    },
    "faq_section": {
      "when": "Price > $50, or complex service, or high-consideration purchase",
      "alternatives": [
        {
          "option": "accordion_faq",
          "when": "Standard \u2014 5-7 questions, saves space"
        },
        {
          "option": "linked_faq_page",
          "when": "10+ questions, needs dedicated page"
        },
        {
          "option": "inline_expand",
          "when": "Short FAQ (3-4 questions), keep user on page"
        },
        {
          "option": "two_column",
          "when": "Visual FAQ with icons, creative brands"
        }
      ]
    },
    "countdown_timer": {
      "when": "Time-limited offer exists, or event has a date",
      "alternatives": [
        {
          "option": "hero_countdown",
          "when": "Primary urgency driver, event registration"
        },
        {
          "option": "offer_bar",
          "when": "Secondary urgency, supplement to main CTA"
        },
        {
          "option": "checkout_countdown",
          "when": "Order page, prevents cart abandonment"
        },
        {
          "option": "static_scarcity",
          "when": "'Only 100 spots' \u2014 no timer, just count"
        }
      ]
    },
    "video": {
      "when": "Complex product needs demonstration, or trust-building needed fast",
      "alternatives": [
        {
          "option": "hero_vsl",
          "when": "Primary sales tool, VSL funnel, info products"
        },
        {
          "option": "product_demo",
          "when": "SaaS, software \u2014 show the interface"
        },
        {
          "option": "explainer",
          "when": "Complex service needs quick explanation"
        },
        {
          "option": "testimonial_video",
          "when": "High ticket, face-to-face trust needed"
        },
        {
          "option": "background_video",
          "when": "Ambient, brand-building, not instructional"
        }
      ]
    },
    "form": {
      "when": "Need to collect user data \u2014 email, contact, or payment info",
      "alternatives": [
        {
          "option": "single_email",
          "when": "Lead magnet, minimum friction"
        },
        {
          "option": "name_email",
          "when": "Standard optin, slight qualification"
        },
        {
          "option": "full_contact",
          "when": "Webinar registration, needs more data"
        },
        {
          "option": "application",
          "when": "High ticket service, needs qualification"
        },
        {
          "option": "billing_checkout",
          "when": "Payment collection, full address + payment"
        },
        {
          "option": "multi_step",
          "when": "Long form, reduces abandonment per step"
        }
      ]
    },
    "footer": {
      "when": "Every page needs one \u2014 legal requirement + trust signal",
      "alternatives": [
        {
          "option": "minimal_legal",
          "when": "Simple funnel, privacy + terms only"
        },
        {
          "option": "with_social",
          "when": "Brand building, community engagement desired"
        },
        {
          "option": "with_menu",
          "when": "Multi-page site, needs navigation"
        },
        {
          "option": "with_cta",
          "when": "Long page, footer is last chance for conversion"
        },
        {
          "option": "with_newsletter",
          "when": "Content site, email list building continues"
        }
      ]
    },
    "thank_you_page": {
      "when": "After every conversion event \u2014 purchase, signup, booking, download",
      "alternatives": [
        {
          "option": "purchase_confirmation",
          "when": "After payment \u2014 receipt + delivery info"
        },
        {
          "option": "appointment_confirmed",
          "when": "After booking \u2014 expectations + phone number"
        },
        {
          "option": "download_access",
          "when": "After optin \u2014 link to content + next steps"
        },
        {
          "option": "registration_success",
          "when": "After event signup \u2014 calendar + reminders"
        },
        {
          "option": "trial_welcome",
          "when": "After trial signup \u2014 onboarding + support"
        },
        {
          "option": "with_upsell",
          "when": "After any conversion \u2014 cross-sell opportunity"
        }
      ]
    }
  },
  "decision_matrix": "For any combination of conditions, the engine selects: funnel_type \u2192 pages \u2192 elements \u2192 copy_formula \u2192 design_palette \u2192 urgency_pattern"
}